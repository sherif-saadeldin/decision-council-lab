LLM_MODE=mock

# --- OpenAI direct ---
# LLM_MODE=openai
# Optional if stored via: uv run python main.py secrets set OPENAI_API_KEY
OPENAI_API_KEY=
DEFAULT_MODEL_OPENAI=gpt-4.1-mini

# --- OpenAI-compatible (OpenRouter, Groq, Together, Fireworks, DeepInfra, etc.) ---
# LLM_MODE=openai_compatible
# LLM_PROVIDER_NAME=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# Optional if stored via: uv run python main.py secrets set LLM_API_KEY
# LLM_API_KEY=
# LLM_MODEL=anthropic/claude-sonnet-4.5

# --- Or use a preset (overrides mode/model/base_url; keys still from env above) ---
# uv run python main.py "Your question" --preset openrouter-sonnet
# uv run python main.py --list-presets

# --- Ollama local (OpenAI-compatible API; no paid key — use LLM_API_KEY=ollama) ---
# LLM_API_KEY=ollama
# uv run python main.py "Your question" --preset ollama-qwen
# Model tags in presets are defaults — check `ollama list` and edit council/model_presets.py if needed.

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1

DEFAULT_MODEL_MOCK=mock-council-v1
DEFAULT_MODEL_ANTHROPIC=
DEFAULT_MODEL_GEMINI=

RUNS_DIR=./runs
